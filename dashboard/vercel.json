{
  "version": 2,
  "framework": "vite",
  "buildCommand": "cd dashboard && npm ci && npm run build",
  "outputDirectory": "dashboard/dist",
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
