generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TimelineType {
  EDUCATION
  JOB
  FREELANCE
  VOLUNTEER
  ACHIEVEMENT
  PLAN
  BLOCKCHAIN
  FOUNDER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  role         Role     @default(ADMIN)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Blog {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String?
  coverImage    String?
  category      String?
  published     Boolean  @default(false)
  featured      Boolean  @default(false)
  views         Int      @default(0)
  readTime      Int?
  tags          String[]
  contentSource String?  @default("richtext")
  metaTitle     String?
  metaDesc      String?
  commentsEnabled Boolean @default(true)
  comments      Comment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Article {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  content    String
  excerpt    String?
  coverImage String?
  published  Boolean  @default(false)
  tags       String[]
  metaTitle  String?
  metaDesc   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Book {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  coverImage  String?
  price       Decimal
  fileUrl     String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CareerTimeline {
  id           String       @id @default(uuid())
  type         TimelineType
  title        String
  organisation String?
  description  String?
  date         String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean      @default(false)
  points       String[]
  keySkills    String[]
  order        Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Download {
  id          String   @id @default(uuid())
  label       String
  fileUrl     String
  publicId    String?
  version     String?
  headline    String?
  lastUpdated String?
  active      Boolean  @default(true)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String
  longDescription String?
  stack           String[]
  tags            String[]
  projectType     String   @default("personal")
  featured        Boolean  @default(false)
  liveUrl         String?
  githubUrl       String?
  coverImage      String?
  typographicMark String?
  order           Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum TechCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  THREED
  TOOLS
  STATE
  BLOCKCHAIN
  OTHER
  LANGUAGES
}

model Skill {
  id        String       @id @default(uuid())
  name      String
  category  TechCategory
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  role        String
  designation String?
  company     String
  quote       String
  initials    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteProfile {
  id            String   @id @default(uuid())
  firstName     String
  middleName    String?
  lastName      String
  alias         String?
  tagline       String?
  subTagline    String?
  fullHeadline  String?
  bio1          String?
  bio2          String?
  pullQuote     String?
  availability  String   @default("Available for work")
  email         String
  phone         String?
  location      String?
  locationShort String?
  timezone      String?
  github        String?
  linkedin      String?
  youtube       String?
  twitter       String?
  portfolio     String?
  calendly      String?
  updatedAt     DateTime @updatedAt
}

model Polaroid {
  id        String   @id @default(uuid())
  src       String   @default("")
  alt       String
  caption   String
  rotation  Float    @default(0)
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  name      String
  email     String
  website   String?
  body      String   @db.Text
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  approved  Boolean  @default(false)
  spam      Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogId])
  @@index([parentId])
  @@index([approved])
  @@index([email])
}

model GuestbookEntry {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.VarChar(280)
  handle    String?  @db.VarChar(80)
  approved  Boolean  @default(false)
  pinned    Boolean  @default(false)
  flagged   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
  @@index([pinned])
  @@index([createdAt])
}
